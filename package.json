{
  "name": "ogre-brand-kit",
  "version": "1.0.0",
  "description": "OGRE Design System - Tailwind preset, design tokens, and React components",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./preset": {
      "import": {
        "types": "./dist/tailwind.preset.d.ts",
        "default": "./dist/tailwind.preset.js"
      },
      "require": {
        "types": "./dist/tailwind.preset.d.cts",
        "default": "./dist/tailwind.preset.cjs"
      }
    },
    "./tokens": {
      "import": {
        "types": "./dist/tokens.d.ts",
        "default": "./dist/tokens.js"
      },
      "require": {
        "types": "./dist/tokens.d.cts",
        "default": "./dist/tokens.cjs"
      }
    },
    "./components": {
      "import": {
        "types": "./dist/components/index.d.ts",
        "default": "./dist/components/index.js"
      },
      "require": {
        "types": "./dist/components/index.d.cts",
        "default": "./dist/components/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./styles/theme.css": "./styles/theme.css",
    "./styles/base.css": "./styles/base.css",
    "./styles/components.css": "./styles/components.css",
    "./assets/*": "./assets/*"
  },
  "files": [
    "dist",
    "styles",
    "assets"
  ],
  "scripts": {
    "dev": "vite --mode demo",
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router-dom": "^6.0.0 || ^7.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.4.0"
  },
  "keywords": [
    "ogre",
    "design-system",
    "tailwind",
    "tailwindcss",
    "react",
    "components"
  ],
  "author": "OGRE",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/ogre-brand-kit.git"
  }
}
